# Django settings
SECRET_KEY=your-django-production-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.onrender.com,localhost,127.0.0.1

# Database Configuration (PostgreSQL URL)
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgres://user:password@hostname:port/dbname

# CORS allowed frontend domains (comma separated)
# Example: https://yourfrontend.vercel.app
FRONTEND_URL=https://yourfrontend.vercel.app
